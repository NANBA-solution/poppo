{
  "name": "poppo",
  "version": "1.0.1",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "start:dev": "expo start --dev-client",
    "start:dev:sim": "expo start --dev-client --localhost",
    "start:dev:tunnel": "expo start --dev-client --tunnel",
    "start:dev:usb": "bash scripts/start-dev-usb.sh",
    "open:ios:sim": "REACT_NATIVE_PACKAGER_HOSTNAME=127.0.0.1 expo run:ios --device 9854EA71-D57B-42F5-BC91-27F5F67617AC",
    "start:dev:clear": "expo start --dev-client --clear",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "prebuild:ios": "expo prebuild --platform ios",
    "prebuild:ios:clean": "expo prebuild --platform ios --clean",
    "pod:install": "cd ios && LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8 pod install",
    "prepare:xcode:ios": "bash scripts/prepare-xcode-ios.sh",
    "run:ios": "expo run:ios",
    "run:ios:device": "expo run:ios --device",
    "build:dev:ios": "expo run:ios --device",
    "build:dev:ios:device": "expo run:ios --device 00008110-001C29C011D9A01E --no-bundler",
    "dev:ios": "expo run:ios --device 00008110-001C29C011D9A01E",
    "open:ios:device": "bash scripts/open-ios-device.sh",
    "build:dev:ios:sim": "LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8 REACT_NATIVE_PACKAGER_HOSTNAME=127.0.0.1 expo run:ios --device 9854EA71-D57B-42F5-BC91-27F5F67617AC --no-install",
    "build:dev:ios:cloud": "eas build --profile development --platform ios",
    "build:preview:ios:cloud": "eas build --profile preview --platform ios",
    "build:dev:android": "expo run:android --device",
    "build:dev:android:local": "expo run:android"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-ml-kit/image-labeling": "^2.0.0",
    "@supabase/supabase-js": "^2.106.2",
    "dotenv": "^17.4.2",
    "expo": "~54.0.33",
    "expo-av": "~16.0.8",
    "expo-build-properties": "~1.0.10",
    "expo-camera": "~17.0.10",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.9",
    "expo-dev-client": "~6.0.21",
    "expo-file-system": "~19.0.22",
    "expo-haptics": "~15.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-intent-launcher": "~13.0.8",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-media-library": "~18.2.1",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.23",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "poppo-cards": "file:modules/poppo-cards",
    "poppo-icons": "file:modules/poppo-icons",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-share": "^12.3.1",
    "react-native-svg": "15.12.1",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-view-shot": "4.0.3"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@types/react": "~19.1.0",
    "babel-plugin-module-resolver": "^5.0.3",
    "typescript": "~5.9.2"
  },
  "private": true,
  "overrides": {
    "react-dom": "19.1.0"
  }
}
