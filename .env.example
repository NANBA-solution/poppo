# --- 開発（Expo Go / ローカル）---
# Anthropic API をアプリから直接叩く（本番では使わないこと）
EXPO_PUBLIC_ANTHROPIC_API_KEY=

# 任意（未設定時: claude-sonnet-4-6）
# EXPO_PUBLIC_ANTHROPIC_MODEL=claude-sonnet-4-6

# --- 本番（推奨）---
# Vercel 等にデプロイした API のベース URL（末尾スラッシュなし）
# EXPO_PUBLIC_API_BASE_URL=https://your-app.vercel.app

# API と同じ値を Vercel の POPPO_API_SECRET に設定（任意・推奨）
# EXPO_PUBLIC_POPPO_API_SECRET=

# Instagram ストーリー直投稿（iOS 本番ビルド用・Meta App ID）
# EXPO_PUBLIC_FACEBOOK_APP_ID=

# EAS プロジェクト ID（任意・app.config.js に既定値あり）
# EAS_PROJECT_ID=1b5fe20e-c747-49e1-9b2f-ffa8f3cdbb7e

# --- Supabase（ぽっぽフィード・クラウド共有）---
# 未設定時は端末内デモフィードのみ。セットアップ: docs/SUPABASE_SETUP.md
# EXPO_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
# EXPO_PUBLIC_SUPABASE_ANON_KEY=
